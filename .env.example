# Hostinger SMTP settings for the PHP contact form.
# Copy this file to .env on the server and fill in the real password there.

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_VERIFY_PEER=true
SMTP_USERNAME=info@carinaschoppe.com
SMTP_PASSWORD=CHANGE_ME

MAIL_FROM=info@carinaschoppe.com
MAIL_FROM_NAME="Carina Sophie Schoppe Website"
MAIL_TO=info@carinaschoppe.com

# auto tries SMTP first and PHP mail as fallback. Use mail only if Hostinger blocks SMTP sockets.
CONTACT_TRANSPORT=auto

# Set to true only while debugging failed contact-form sends.
CONTACT_DEBUG=false
